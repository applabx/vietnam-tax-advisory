# Production webhook for the contact form
# Should point to the deployed Cloudflare Worker (or Formspree, Zapier, etc.)
# Set in Cloudflare Pages → Settings → Environment variables
NEXT_PUBLIC_CONTACT_WEBHOOK=https://vietnam-tax-advisory-contact.<your-subdomain>.workers.dev

# Lead-magnet form (defaults to the contact webhook if unset)
NEXT_PUBLIC_LEAD_WEBHOOK=https://vietnam-tax-advisory-contact.<your-subdomain>.workers.dev

# Public CRM webhook (informational; actual forwarding happens in the worker)
NEXT_PUBLIC_CRM_WEBHOOK=
